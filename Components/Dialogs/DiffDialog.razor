@using LlmContextCollector.Models
@using LlmContextCollector.Utils
@using LlmContextCollector.Services
@using System.Text.RegularExpressions
@using System.Threading
@inject IClipboard Clipboard
@inject AppState AppState
@inject GitWorkflowService GitWorkflowService
@inject GitSuggestionService GitSuggestionService
@inject IJSRuntime JSRuntime
@implements IDisposable

@if (IsVisible)
{
    <div class="modal-backdrop" 
         @onclick="HideContextMenu" 
         @onmousemove="OnMouseMove" 
         @onmouseup="StopPaneResize"
         @onmouseleave="StopPaneResize">
        <div class="modal-dialog diff-dialog">
            <div class="modal-header">
                <h3>@(_isGitDiffMode ? "Git Változások Áttekintése" : "AI Válasz Alkalmazása")</h3>
                <div class="header-controls">
                    @if (!string.IsNullOrEmpty(FullLlmResponse))
                    {
                        <button @onclick="ToggleFullResponseView">
                            @(_isFullResponseView ? "Vissza a Változásokhoz" : "Teljes LLM Válasz")
                        </button>
                    }
                    <button class="close-btn" @onclick="Close">&times;</button>
                </div>
            </div>
            <div class="modal-body diff-body">
                @if (_isManualMergeMode && _selectedResult != null)
                {
                    <div class="manual-merge-view">
                        <div class="manual-merge-toolbar">
                            <div style="display: flex; flex-direction: column; gap: 4px;">
                                <strong>Kézi beolvasztás: @_selectedResult.Path</strong>
                                <div style="display: flex; gap: 5px; align-items: center;">
                                    <input type="text" placeholder="Keresés..." @bind="_mergeSearchTerm" @bind:event="oninput" @bind:after="UpdateMergeHighlighting" style="width: 250px; height: 24px; font-size: 11px;" />
                                    <button class="icon-btn-small" @onclick="() => NavigateFailedPatch(-1)" title="Előző sor a patch-ből">▲</button>
                                    <button class="icon-btn-small" @onclick="() => NavigateFailedPatch(1)" title="Következő sor a patch-ből">▼</button>
                                    @if (_currentFailedLineIndex >= 0) {
                                        <span style="font-size: 10px; color: var(--text-color-light);">Sor: @(_currentFailedLineIndex + 1)/@_failedPatchLines.Count</span>
                                    }
                                </div>
                            </div>
                            <div style="display: flex; gap: 10px;">
                                <button @onclick="CloseManualMerge">Mégsem</button>
                                <button class="primary" @onclick="SaveManualMerge">Beolvasztás befejezése</button>
                            </div>
                        </div>
                        <div class="manual-merge-editors">
                            <div class="merge-editor-pane">
                                <div class="editor-header">Sikertelen LLM Patch (Navigálható)</div>
                                <div class="merge-textarea" style="overflow: auto; background-color: var(--input-disabled-bg-color);">
                                    <pre style="margin:0; font-family: inherit; font-size: inherit; white-space: pre;">@_highlightedFailedPatch</pre>
                                </div>
                            </div>
                            <div class="merge-editor-pane">
                                <div class="editor-header">Végeredmény (Szerkeszthető)</div>
                                <textarea id="merge-editor-main" class="merge-textarea" @bind="_manualMergeNewContent" @bind:event="oninput"></textarea>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                <div class="diff-left-pane" style="width: @(_leftPaneWidthPercent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;">
                    @if (_isGitDiffMode)
                    {
                        <div class="diff-selector-box">
                            <div style="display:flex; justify-content: space-between; align-items: center;">
                                <strong>Különbségek forrása:</strong>
                                <span class="badge-mode">GIT MÓD</span>
                            </div>
                            <div class="diff-options">
                                <label><input type="radio" name="diff-mode" @onchange="() => ChangeViewMode(ViewMode.Uncommitted)" checked="@(_selectedViewMode == ViewMode.Uncommitted)" /> Jelenlegi változások</label>
                                <label><input type="radio" name="diff-mode" @onchange="() => ChangeViewMode(ViewMode.SinceBranchCreation)" checked="@(_selectedViewMode == ViewMode.SinceBranchCreation)" /> Branch nyitása óta</label>
                                <label><input type="radio" name="diff-mode" @onchange="() => ChangeViewMode(ViewMode.AgainstBranch)" checked="@(_selectedViewMode == ViewMode.AgainstBranch)" /> Másik branch-hez képest</label>
                                <label><input type="radio" name="diff-mode" @onchange="() => ChangeViewMode(ViewMode.LlmHistory)" checked="@(_selectedViewMode == ViewMode.LlmHistory)" /> Elfogadott LLM válaszok</label>
                            </div>
                            @if (_selectedViewMode == ViewMode.AgainstBranch)
                            {
                                <select @bind="_selectedTargetBranch">
                                    @foreach (var branch in _allBranches)
                                    {
                                        <option value="@branch">@branch</option>
                                    }
                                </select>
                            }
                            @if (_selectedViewMode == ViewMode.LlmHistory)
                            {
                                <select @onchange="OnHistoryEntrySelected">
                                    <option value="" selected="@(_selectedHistoryEntryId == null)">Válassz előzményt...</option>
                                    @foreach (var entry in _historyEntries)
                                    {
                                        <option value="@entry.Id" selected="@(_selectedHistoryEntryId == entry.Id)">
                                            @entry.Timestamp.ToString("yyyy.MM.dd HH:mm") - @GetSnippet(entry.Explanation)
                                        </option>
                                    }
                                </select>
                            }
                            @if (_selectedViewMode != ViewMode.LlmHistory)
                            {
                                <button @onclick="LoadSelectedDiffsAsync" disabled="@_isLoadingDiffs">
                                    @if (_isLoadingDiffs)
                                    {
                                        <span class="spinner-small"></span>
                                    }
                                    else
                                    {
                                        <span>Különbségek mutatása</span>
                                    }
                                </button>
                            }
                        </div>
                    }

                    <div class="suggestion-box">
                        <div class="suggestion-header">
                            <div style="display:flex; flex-direction:column; gap:2px;">
                                <strong>@(_hasSuggestions ? "Javaslatok:" : "Git Műveletek")</strong>
                                <label style="font-size: 10px; font-weight: normal; cursor: pointer; display: flex; align-items: center; gap: 4px;">
                                    <input type="checkbox" @bind="_includeOriginalPromptInSuggestions" style="width: auto; height: auto;" /> Eredeti prompt küldése
                                </label>
                            </div>
                            <button class="refresh-btn" @onclick="RefreshSuggestionsAsync" title="Javaslatok újragenerálása" disabled="@_isRefreshingSuggestions">
                                @if (_isRefreshingSuggestions)
                                {
                                    <span class="spinner-small"></span>
                                }
                                else
                                {
                                    <span>🔄</span>
                                }
                            </button>
                        </div>
                        <div class="suggestion-item">
                            <label>Branch:</label>
                            <input type="text" @bind="_suggestedBranch" placeholder="pl. feature/uj-funkcio" />
                            @if (_hasSuggestions)
                            {
                                <button @onclick="() => CopyToClipboard(_suggestedBranch)">Másol</button>
                            }
                        </div>
                        <div class="suggestion-item">
                            <label>Commit:</label>
                            <textarea rows="5" @bind="_suggestedCommit" placeholder="pl. feat: Új funkció implementálása..."></textarea>
                            @if (_hasSuggestions)
                            {
                                <button @onclick="() => CopyToClipboard(_suggestedCommit)">Másol</button>
                            }
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(_globalExplanationText))
                    {
                        <div class="diff-global-explanation">
                            <strong>Globális Magyarázat:</strong>
                            <pre>@_globalExplanationText</pre>
                        </div>
                    }
                    <strong>Feldolgozott fájlok: (@_localDiffResults.Count)</strong>
                    <fieldset class="file-list-fieldset" disabled="@_isFullResponseView">
                        <div class="diff-file-list">
                            @foreach (var result in _localDiffResults)
                            {
                                <div @key="result.Path"
                                     class="diff-file-item @GetStatusClass(result) @(_selectedResult != null && _selectedResult.Path == result.Path ? "selected" : "")"
                                     @onclick="() => SelectResult(result)">
                                    <input type="checkbox" @bind="result.IsSelectedForAccept" @onclick:stopPropagation />
                                    <span class="status-badge @GetStatusClass(result)">@GetStatusText(result)</span>
                                    <span class="file-path-text" title="@result.Path">@result.Path</span>
                                    
                                    <div class="item-actions">
                                        @if (result.PatchFailed)
                                        {
                                            <span class="patch-failed-indicator" title="Sikertelen beolvasztás">⚠️</span>
                                        }
                                        @if (!string.IsNullOrEmpty(result.Explanation))
                                        {
                                            <span class="comment-indicator" title="Van magyarázat">💬</span>
                                        }
                                        <button class="reset-btn" @onclick="() => RevertFile(result)" @onclick:stopPropagation title="Változások eldobása / visszaállítása">
                                            ↩️
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </fieldset>
                </div>

                <div class="diff-splitter" @onmousedown="StartPaneResize"></div>

                <div class="diff-right-pane" style="width: @((100 - _leftPaneWidthPercent).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;">
                    @if (_isFullResponseView)
                    {
                        <div class="full-response-view">
                            <strong>Teljes LLM válasz:</strong>
                            <textarea readonly>@FullLlmResponse</textarea>
                        </div>
                    }
                    else if (_isGeneratingDiff)
                    {
                        <div class="editor-placeholder">
                            <div class="spinner-small"></div>
                            <span>Különbségek számítása...</span>
                        </div>
                    }
                    else if (_selectedResult != null)
                    {
                         @if (!string.IsNullOrEmpty(_selectedResult.Explanation))
                        {
                            <div class="file-explanation-box">
                                <strong>@_selectedResult.Path - Magyarázat:</strong>
                                <p>@_selectedResult.Explanation</p>
                            </div>
                        }

                        @if (_selectedResult.PatchFailed)
                        {
                            <div class="patch-failed-warning">
                                <strong>Figyelem!</strong> Az automatikus beolvasztás sikertelen (SEARCH blokk nem található).
                                <button class="primary" style="margin-top: 5px;" @onclick="() => OpenManualMerge(_selectedResult)">Kézi beolvasztás megnyitása</button>
                            </div>
                        }
                        
                        <div class="diff-content-wrapper">
                            <div class="diff-content unified-diff-list">
                                @foreach (var line in _unifiedDiffLines)
                                {
                                    <div class="diff-row @GetDiffLineClass(line)" @oncontextmenu="(e) => ShowLineContextMenu(e, line)" @oncontextmenu:preventDefault>
                                        <span class="diff-marker-text">@GetDiffLineMarker(line)</span>
                                        <span class="diff-text">@line.Content</span>
                                    </div>
                                }
                            </div>
                            <div class="diff-scrollbar-track">
                                @foreach (var marker in _unifiedDiffMarkers)
                                {
                                    <div class="diff-marker @marker.Type" style="top: @marker.TopPercent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                }
                            </div>
                        </div>

                        @if (_showContextMenu && _contextMenuTargetLine != null && _contextMenuTargetLine.Type == DiffUtility.DiffLineType.Add)
                        {
                            <div class="context-menu" style="top: @(_contextMenuY)px; left: @(_contextMenuX)px;" @onclick:stopPropagation>
                                <div class="context-menu-item" @onclick="DeleteLine">Sor törlése</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="editor-placeholder">Válassz egy fájlt a változások megtekintéséhez.</div>
                    }
                </div>
                }
            </div>
            <div class="modal-footer">
                <span>@($"{_localDiffResults.Count(r => r.IsSelectedForAccept)} fájl kijelölve")</span>
                <button @onclick="Close">Bezárás</button>
                @if (_selectedViewMode == ViewMode.LlmHistory && _isGitDiffMode)
                {
                    <button class="primary" style="background-color: #6c757d; border-color: #6c757d;" @onclick="RevertEntireHistoryEntryAsync" disabled="@(_selectedHistoryEntryId == null)">Visszaállás erre a pontra</button>
                    <button class="primary" style="background-color: #dc3545; border-color: #dc3545;" @onclick="RevertSelectedHistoryChanges" disabled="@(!_localDiffResults.Any(r => r.IsSelectedForAccept))">Kijelöltek visszavonása</button>
                }
                else
                {
                    @if (_localDiffResults.Any(r => r.PatchFailed))
                    {
                        <button class="secondary" style="background-color: #2a9d8f; color: white; border: none;" @onclick="ProcessFixFromClipboardAsync" title="A vágólapon lévő javított blokkok beolvasása és összefésülése a jelenlegi listával">✨ Javítás Feldolgozása (Vágólapról)</button>
                        <button class="primary" style="background-color: #e67e22; border-color: #d35400;" @onclick="CopyFixPromptToClipboard" title="Összeállít egy visszakérdezést az LLM-nek a hibás blokkokról">⚠️ Hibajavító Prompt Másolása</button>
                    }

                    @if (!_isGitDiffMode)
                    {
                        <button class="primary" @onclick="AcceptSelectedChanges" disabled="@(!_localDiffResults.Any(r => r.IsSelectedForAccept))">Változások Alkalmazása</button>
                    }
                    else
                    {
                        <button class="primary" @onclick="AcceptSelectedChanges" disabled="@(!_localDiffResults.Any(r => r.IsSelectedForAccept))">Kijelöltek Elfogadása</button>
                    }

                    <button class="primary" @onclick="CreateBranch" disabled="@(string.IsNullOrWhiteSpace(_suggestedBranch))">Branch Létrehozása</button>
                    <button class="primary" @onclick="Commit" disabled="@(string.IsNullOrWhiteSpace(_suggestedCommit) || !_localDiffResults.Any(r => r.IsSelectedForAccept))">Commit</button>
                    <button class="primary commit-btn" @onclick="Push">Push</button>
                }
            </div>
        </div>
    </div>
}