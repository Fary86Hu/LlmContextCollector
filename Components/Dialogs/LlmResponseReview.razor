@using LlmContextCollector.Models
@using LlmContextCollector.Utils
@using LlmContextCollector.Services
@using System.Text.RegularExpressions
@inject GitWorkflowService GitWorkflowService
@inject IJSRuntime JSRuntime
@implements IDisposable

@if (IsVisible)
{
    <div class="modal-backdrop" 
         @onclick="HideContextMenu" 
         @onmousemove="OnMouseMove" 
         @onmouseup="StopPaneResize"
         @onmouseleave="StopPaneResize">
        <div class="modal-dialog review-dialog">
            <div class="modal-header">
                <h3>AI Válasz Alkalmazása</h3>
                <div class="header-controls">
                    @if (!string.IsNullOrEmpty(FullLlmResponse))
                    {
                        <button @onclick="ToggleFullResponseView">
                            @(_isFullResponseView ? "Vissza a Változásokhoz" : "Teljes LLM Válasz")
                        </button>
                    }
                    <button class="close-btn" @onclick="Close">&times;</button>
                </div>
            </div>
            <div class="modal-body review-body">
                @if (_isFullResponseView)
                {
                    <div class="full-response-container">
                        <strong>Teljes LLM válasz forrása:</strong>
                        <textarea readonly class="full-response-textarea">@FullLlmResponse</textarea>
                    </div>
                }

                <div class="review-left-pane" style="width: @(_leftPaneWidthPercent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;">

                    @if (!string.IsNullOrEmpty(GlobalExplanation))
                    {
                        <div class="global-explanation-box">
                            <strong>Globális Magyarázat:</strong>
                            <pre>@_globalExplanationText</pre>
                        </div>
                    }
                    <strong>Módosított fájlok: (@_localDiffResults.Count)</strong>
                    <div class="review-file-list-container @(_isFullResponseView ? "disabled" : "")">
                        <div class="review-file-list">
                            @foreach (var result in _localDiffResults)
                            {
                                <div @key="result.Path"
                                     class="review-file-item @GetStatusClass(result) @(_selectedResult != null && _selectedResult.Path == result.Path ? "selected" : "")"
                                     @onclick="() => SelectResult(result)">
                                    <input type="checkbox" @bind="result.IsSelectedForAccept" @onclick:stopPropagation disabled="@_isFullResponseView" />
                                    <span class="status-badge @GetStatusClass(result)">@GetStatusText(result)</span>
                                    <span class="file-path-text" title="@result.Path">@result.Path</span>

                                    <div class="item-actions">
                                        @if (result.PatchFailed)
                                        {
                                            <span class="patch-failed-indicator" title="Sikertelen beolvasztás">⚠️</span>
                                        }
                                        @if (!string.IsNullOrEmpty(result.Explanation))
                                        {
                                            <span class="comment-indicator" title="Van magyarázat">💬</span>
                                        }

                                        <div class="history-nav-group" @onclick:stopPropagation>
                                            <button class="history-btn" @onclick="() => NavigateFileHistoryAsync(result, 1)" disabled="@(!HasMoreHistory(result, 1) || _isFullResponseView)" title="Vissza a történetben">◀</button>
                                            <span class="history-pointer" @onclick:stopPropagation>@GetHistoryPointerText(result)</span>
                                            <button class="history-btn" @onclick="() => NavigateFileHistoryAsync(result, -1)" disabled="@(!HasMoreHistory(result, -1) || _isFullResponseView)" title="Előre a történetben">▶</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="review-splitter" @onmousedown="StartPaneResize"></div>

                <div class="review-right-pane" style="width: @((100 - _leftPaneWidthPercent).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;">
                    @if (_isGeneratingDiff)
                    {
                        <div class="editor-placeholder">
                            <div class="spinner-small"></div>
                            <span>Különbségek számítása...</span>
                        </div>
                    }
                    else if (_selectedResult != null)
                    {
                        @if (!string.IsNullOrEmpty(_selectedResult.FailedPatchContent))
                        {
                            <div class="right-top-block-pane" style="height: @(_topPaneHeightPercent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;">
                                <div class="block-viewer-header">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <strong>LLM Blokkok forrása: @_selectedResult.Path</strong>
                                        <div class="block-nav-controls">
                                            <button class="icon-btn-small" @onclick="() => NavigatePatchBlock(-1)" title="Előző blokk">▲</button>
                                            <span class="block-counter">@(_currentPatchBlockIndex + 1) / @_patchBlockCount</span>
                                            <button class="icon-btn-small" @onclick="() => NavigatePatchBlock(1)" title="Következő blokk">▼</button>
                                        </div>
                                    </div>
                                    <span class="status-indicator @(_selectedResult.PatchFailed ? "failed" : "success")">
                                        @(_selectedResult.PatchFailed ? "BEOLVASZTÁS SIKERTELEN" : "BEOLVASZTÁS SIKERES")
                                    </span>
                                </div>
                                <textarea id="patch-block-textarea" class="block-content-textarea" readonly>@_selectedResult.FailedPatchContent</textarea>
                            </div>

                            <div class="diff-h-splitter" @onmousedown="StartTopPaneResize"></div>

                            <div class="right-bottom-diff-pane" style="height: @((100 - _topPaneHeightPercent).ToString("F2", System.Globalization.CultureInfo.InvariantCulture))%;">
                                @if (_selectedResult.PatchFailed)
                                {
                                    <div class="patch-failed-warning error-border">
                                        <div><strong>Figyelem!</strong> Az automatikus beolvasztás sikertelen. Használja a szerkesztő módot a javításhoz.</div>
                                    </div>
                                }

                                <div class="diff-toolbar">
                                    <span class="toolbar-label">Változások áttekintése</span>
                                    <div style="flex-grow: 1;"></div>
                                    <button class="icon-btn-small @(_isManualEditMode ? "active" : "")" @onclick="ToggleManualEdit" title="@(_isManualEditMode ? "Vissza nézetre" : "Kézi szerkesztés")">
                                        @(_isManualEditMode ? "👁️" : "✏️")
                                    </button>
                                </div>

                                <div class="diff-content-wrapper">
                                    @if (_isManualEditMode)
                                    {
                                        <textarea class="manual-edit-textarea" @bind="_selectedResult.NewContent" @bind:event="oninput"></textarea>
                                    }
                                    else
                                    {
                                        <div id="diff-view-container" class="diff-content unified-diff-list">
                                            @for (int i = 0; i < _unifiedDiffLines.Count; i++)
                                            {
                                                var line = _unifiedDiffLines[i];
                                                var idx = i;
                                                <div id="diff-row-@idx" class="diff-row @GetDiffLineClass(line) @(idx == _activeDiffHighlightIndex ? "nav-highlight" : "")" @oncontextmenu="(e) => ShowLineContextMenu(e, line)" @oncontextmenu:preventDefault>
                                                    <span class="diff-marker-text">@GetDiffLineMarker(line)</span>
                                                    <span class="diff-text">@line.Content</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    <div class="diff-scrollbar-track">
                                        @foreach (var marker in _unifiedDiffMarkers)
                                        {
                                            <div class="diff-marker @marker.Type" style="top: @marker.TopPercent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="right-bottom-diff-pane" style="height: 100%;">
                                @if (!string.IsNullOrEmpty(_selectedResult.Explanation))
                                {
                                    <div class="file-explanation-box">
                                        <strong>Magyarázat:</strong>
                                        <p>@_selectedResult.Explanation</p>
                                    </div>
                                }

                                <div class="diff-toolbar">
                                    <span class="toolbar-label">Változások áttekintése</span>
                                    <div style="flex-grow: 1;"></div>
                                    <button class="icon-btn-small @(_isManualEditMode ? "active" : "")" @onclick="ToggleManualEdit" title="@(_isManualEditMode ? "Vissza nézetre" : "Kézi szerkesztés")">
                                        @(_isManualEditMode ? "👁️" : "✏️")
                                    </button>
                                </div>

                                <div class="diff-content-wrapper">
                                    @if (_isManualEditMode)
                                    {
                                        <textarea class="manual-edit-textarea" @bind="_selectedResult.NewContent" @bind:event="oninput"></textarea>
                                    }
                                    else
                                    {
                                        <div id="diff-view-container" class="diff-content unified-diff-list">
                                            @for (int i = 0; i < _unifiedDiffLines.Count; i++)
                                            {
                                                var line = _unifiedDiffLines[i];
                                                var idx = i;
                                                <div id="diff-row-@idx" class="diff-row @GetDiffLineClass(line) @(idx == _activeDiffHighlightIndex ? "nav-highlight" : "")" @oncontextmenu="(e) => ShowLineContextMenu(e, line)" @oncontextmenu:preventDefault>
                                                    <span class="diff-marker-text">@GetDiffLineMarker(line)</span>
                                                    <span class="diff-text">@line.Content</span>
                                                </div>
                                            }
                                        </div>
                                    }
                                    <div class="diff-scrollbar-track">
                                        @foreach (var marker in _unifiedDiffMarkers)
                                        {
                                            <div class="diff-marker @marker.Type" style="top: @marker.TopPercent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }

                        @if (_showContextMenu && _contextMenuTargetLine != null && _contextMenuTargetLine.Type == DiffUtility.DiffLineType.Add)
                        {
                            <div class="context-menu" style="top: @(_contextMenuY)px; left: @(_contextMenuX)px;" @onclick:stopPropagation>
                                <div class="context-menu-item" @onclick="DeleteLine">Sor törlése</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="editor-placeholder">Válassz egy fájlt a változások megtekintéséhez.</div>
                    }
                </div>
                }
            </div>
            <div class="modal-footer">
                <span>@($"{_localDiffResults.Count(r => r.IsSelectedForAccept)} fájl kijelölve")</span>
                <div style="flex-grow: 1;"></div>
                <button @onclick="Close">Bezárás</button>
                @if (_localDiffResults.Any(r => r.PatchFailed))
                {
                    <button class="secondary" style="background-color: #2a9d8f; color: white;" @onclick="ProcessFixFromClipboardAsync">✨ Javítás Feldolgozása</button>
                    <button class="primary" style="background-color: #e67e22;" @onclick="CopyFixPromptToClipboard">⚠️ Hibajavító Prompt Másolása</button>
                }
                <button class="primary" @onclick="AcceptSelectedChanges" disabled="@(!_localDiffResults.Any(r => r.IsSelectedForAccept))">Változások Alkalmazása</button>
            </div>
        </div>
    </div>
}