@inject AppState AppState

@if (IsVisible)
{
    <div class="modal-backdrop">
        <div class="modal-dialog">
            <div class="modal-header">
                <h3>Lokalizációs Fájl Beállítása</h3>
                <button class="close-btn" @onclick="Close">&times;</button>
            </div>
            <div class="modal-body">
                <p>
                    Az LLM válasz lokalizációs adatokat tartalmaz, de a projekthez még nincs beállítva a cél resource fájl (.resx).
                    Kérlek, add meg a fájl pontos elérési útját!
                </p>
                <div class="ado-form-group">
                    <label>Resource Fájl (.resx):</label>
                    <div style="display: flex; gap: 5px;">
                        <input type="text" style="flex-grow: 1;" @bind="AppState.LocalizationResourcePath" placeholder="C:\...\Resources\Resource.resx" />
                        <button class="secondary" @onclick="PickResxFile">Tallózás...</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button @onclick="Close">Mégsem</button>
                <button class="primary" @onclick="Confirm" disabled="@(string.IsNullOrWhiteSpace(AppState.LocalizationResourcePath))">Beállítás és Mentés</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<string> OnConfirm { get; set; }

    private async Task PickResxFile()
    {
        try
        {
            var result = await Microsoft.Maui.Storage.FilePicker.Default.PickAsync(new Microsoft.Maui.Storage.PickOptions
            {
                PickerTitle = "Válassz lokalizációs resource (.resx) fájlt",
                FileTypes = new Microsoft.Maui.Storage.FilePickerFileType(new Dictionary<DevicePlatform, IEnumerable<string>>
                {
                    { DevicePlatform.WinUI, new[] { ".resx" } }
                })
            });

            if (result != null)
            {
                AppState.LocalizationResourcePath = result.FullPath;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            AppState.StatusText = $"Hiba a fájlválasztáskor: {ex.Message}";
        }
    }

    private async Task Confirm()
    {
        await OnConfirm.InvokeAsync(AppState.LocalizationResourcePath);
    }

    private async Task Close() => await OnClose.InvokeAsync();
}