@using System.ComponentModel
@using System.Collections.Specialized
@implements IDisposable
@inject AppLogService LogService
@inject AppState AppState
@inject IClipboard Clipboard

@if (AppState.IsAiInspectorVisible)
{
    <div class="modal-backdrop">
        <div class="modal-dialog inspector-dialog">
            <div class="modal-header">
                <h3>Rendszer és AI Napló</h3>
                <div class="header-controls">
                    <button @onclick="CopyLogsToClipboard" class="secondary">Napló másolása</button>
                    <button @onclick="LogService.Clear" class="secondary">Napló ürítése</button>
                    <button class="close-btn" @onclick="Close">&times;</button>
                </div>
            </div>
            <div class="modal-body inspector-body">
                <div class="log-list">
                    @if (!LogService.Logs.Any())
                    {
                        <div class="editor-placeholder">Nincs rögzített esemény.</div>
                    }
                    @foreach (var log in LogService.Logs)
                    {
                        <div class="log-item @(GetLogClass(log)) @(_selectedLog == log ? "selected" : "")" @onclick="() => _selectedLog = log">
                            <div class="log-item-header">
                                <span class="log-time">@log.Timestamp.ToString("HH:mm:ss")</span>
                                <span class="log-type-badge">@log.Type</span>
                            </div>
                            <span class="log-source">@log.Source</span>
                            <span class="log-title">@log.Title</span>
                        </div>
                    }
                </div>
                <div class="log-details">
                    @if (_selectedLog != null)
                    {
                        <div class="detail-header">
                            <div class="header-main">
                                <span class="status-dot @(GetLogClass(_selectedLog))"></span>
                                <h4>@_selectedLog.Title</h4>
                            </div>
                            <div class="meta-info">
                                <span><strong>IDŐ:</strong> @_selectedLog.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff")</span>
                                <span><strong>FORRÁS:</strong> @_selectedLog.Source</span>
                            </div>
                        </div>

                        <div class="detail-scroll-area">
                            @if (_selectedLog.Type == LogType.Ai)
                            {
                                <div class="detail-section">
                                    <label>AI MODELL</label>
                                    <div class="info-value">@_selectedLog.Model</div>
                                </div>
                                <div class="detail-section">
                                    <label>FELHASZNÁLÓI PROMPT</label>
                                    <textarea class="code-font" readonly>@_selectedLog.Prompt</textarea>
                                </div>
                                <div class="detail-section">
                                    <label>MODELL VÁLASZA</label>
                                    <textarea class="code-font" readonly>@_selectedLog.Response</textarea>
                                </div>
                            }
                            else
                            {
                                <div class="detail-section">
                                    <label>NAPLÓZOTT TARTALOM / HIBAÜZENET</label>
                                    <textarea class="code-font" readonly>@_selectedLog.Content</textarea>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="editor-placeholder">
                            <div class="placeholder-content">
                                <span class="icon">🔍</span>
                                <p>Válassz egy bejegyzést a bal oldali listából a részletek megtekintéséhez.</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button @onclick="Close">Bezárás</button>
            </div>
        </div>
    </div>
}

@code {
    private LogEntry? _selectedLog;

    protected override void OnInitialized()
    {
        AppState.PropertyChanged += OnAppStateChanged;
        LogService.Logs.CollectionChanged += OnLogsChanged;
    }

    private string GetLogClass(LogEntry log) => log.Type switch
    {
        LogType.Ai => "log-ai",
        LogType.Error => "log-error",
        LogType.Warning => "log-warning",
        _ => "log-info"
    };

    private async void OnAppStateChanged(object? sender, PropertyChangedEventArgs e)
    {
        if (e.PropertyName == nameof(AppState.IsAiInspectorVisible))
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void OnLogsChanged(object? sender, NotifyCollectionChangedEventArgs e)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.PropertyChanged -= OnAppStateChanged;
        LogService.Logs.CollectionChanged -= OnLogsChanged;
    }

    private void Close() => AppState.IsAiInspectorVisible = false;

    private async Task CopyLogsToClipboard()
    {
        var sb = new System.Text.StringBuilder();
        foreach (var log in LogService.Logs.Reverse())
        {
            sb.AppendLine($"[{log.Timestamp:yyyy-MM-dd HH:mm:ss.fff}] [{log.Type}][{log.Source}] {log.Title}");
            if (!string.IsNullOrWhiteSpace(log.Content))
            {
                sb.AppendLine("  Részletek:");
                sb.AppendLine("  " + log.Content.Replace("\n", "\n  "));
            }
            if (log.Type == LogType.Ai)
            {
                sb.AppendLine($"  Modell: {log.Model}");
                sb.AppendLine($"  Prompt: {log.Prompt}");
                sb.AppendLine($"  Válasz: {log.Response}");
            }
            sb.AppendLine("--------------------------------------------------");
        }
        await Clipboard.SetTextAsync(sb.ToString());
        AppState.StatusText = "Napló a vágólapra másolva.";
    }
}