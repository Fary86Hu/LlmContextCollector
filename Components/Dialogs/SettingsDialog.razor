@inject AppState AppState
@inject SettingsService SettingsService

@if (IsVisible)
{
    <div class="modal-backdrop">
        <div class="modal-dialog settings-large">
            <div class="modal-header">
                <h3>Beállítások</h3>
                <button class="close-btn" @onclick="Close">&times;</button>
            </div>
            <div class="modal-body">
                <div class="settings-grid">
                <div class="settings-nav">
                    <h4>Megjelenés & Rendszer</h4>
                    <div class="form-group">
                        <label>Téma:</label>
                        <select @bind="AppState.Theme">
                            <option value="System">Rendszer</option>
                            <option value="Light">Világos</option>
                            <option value="Dark">Sötét</option>
                        </select>
                    </div>
                    <div class="form-group" style="margin-top: 10px;">
                        <label style="display: flex; align-items: center; gap: 5px; cursor: pointer; font-weight: normal;">
                            <input type="checkbox" @bind="AppState.LogInformationLevel" style="width: auto; margin: 0;" />
                            Info szintű logolás
                        </label>
                    </div>

                    <h4 style="margin-top: 20px;">Modell hozzárendelések</h4>
                    <div class="form-group">
                        <label>Chat funkció:</label>
                        <select @bind="AppState.ChatModelId">
                            <option value="@Guid.Empty">Lokális Ollama (Alapértelmezett)</option>
                            @foreach (var model in AppState.AiModels)
                            {
                                <option value="@model.Id">@model.FriendlyName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group" style="margin-top: 10px;">
                        <label>Ügynök (Implementáció):</label>
                        <select @bind="AppState.AgentModelId">
                            <option value="@Guid.Empty">Lokális Ollama (Alapértelmezett)</option>
                            @foreach (var model in AppState.AiModels)
                            {
                                <option value="@model.Id">@model.FriendlyName</option>
                            }
                        </select>
                    </div>
                    <div class="form-group" style="margin-top: 10px;">
                        <label>Git (Commit & Branch):</label>
                        <select @bind="AppState.GitSuggestionModelId">
                            <option value="@Guid.Empty">Lokális Ollama (Alapértelmezett)</option>
                            @foreach (var model in AppState.AiModels)
                            {
                                <option value="@model.Id">@model.FriendlyName</option>
                            }
                        </select>
                    </div>

                    <h4 style="margin-top: 20px;">Lokális Ollama beállítások</h4>
                    <div class="form-group">
                        <label>Ollama API URL:</label>
                        <input type="text" @bind="AppState.OllamaApiUrl" />
                    </div>
                    <div class="form-group">
                        <label>Ollama Modell név:</label>
                        <input type="text" @bind="AppState.OllamaModel" />
                    </div>

                    <h4 style="margin-top: 20px;">Azure DevOps</h4>
                    <div class="form-group">
                        <label>Szervezet URL:</label>
                        <input type="text" @bind="AppState.AzureDevOpsOrganizationUrl" />
                    </div>
                    <div class="form-group">
                        <label>Projekt Név:</label>
                        <input type="text" @bind="AppState.AzureDevOpsProject" />
                    </div>
                    <div class="form-group">
                        <label>PAT:</label>
                        <input type="password" @bind="AppState.AzureDevOpsPat" />
                    </div>
                </div>

                <div class="settings-content">
                    <div class="header-with-action">
                        <h4>AI Modell Registry</h4>
                        <button class="primary btn-small" @onclick="AddNewModel">＋ Új modell</button>
                    </div>

                    <div class="model-list">
                        @foreach (var model in AppState.AiModels)
                        {
                            <div class="model-card @(_selectedModelId == model.Id ? "selected" : "")" @onclick="() => _selectedModelId = model.Id">
                                <div class="model-card-header">
                                    <strong>@model.FriendlyName</strong>
                                    <div class="card-actions">
                                        <button class="icon-btn-small" @onclick="() => RemoveModel(model)" @onclick:stopPropagation>🗑️</button>
                                    </div>
                                </div>
                                <div class="model-card-meta">@model.ProviderType | @model.ModelName</div>
                            </div>
                        }
                    </div>

                    @if (SelectedModel != null)
                    {
                        <div class="model-editor">
                            <h5>Szerkesztés: @SelectedModel.FriendlyName</h5>
                            <div class="form-row">
                                <div class="form-group">
                                    <label>Megjelenítési név:</label>
                                    <input type="text" @bind="SelectedModel.FriendlyName" />
                                </div>
                                <div class="form-group">
                                    <label>Típus:</label>
                                    <select @bind="SelectedModel.ProviderType">
                                        @foreach (var type in Enum.GetValues<AiProviderType>())
                                        {
                                            <option value="@type">@type</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="form-group">
                                <label>API URL (Base URL):</label>
                                <input type="text" @bind="SelectedModel.ApiUrl" placeholder="https://api.groq.com/openai/v1" />
                            </div>

                            <div class="form-row">
                                <div class="form-group">
                                    <label>Modell azonosító:</label>
                                    <input type="text" @bind="SelectedModel.ModelName" placeholder="gpt-4o, qwen2.5..." />
                                </div>
                                <div class="form-group">
                                    <label>API Kulcs (ha kell):</label>
                                    <input type="password" @bind="SelectedModel.ApiKey" />
                                </div>
                            </div>
                            <div class="form-group">
                                <label>Max Token:</label>
                                <input type="number" @bind="SelectedModel.MaxOutputTokens" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="editor-placeholder">Válassz ki egy modellt a szerkesztéshez vagy adj hozzá egy újat.</div>
                    }
                </div>
                </div>
            </div>
            <div class="modal-footer">
                <button @onclick="Close">Mégsem</button>
                <button class="primary" @onclick="SaveChanges">Minden mentése</button>
            </div>
        </div>
    </div>
}

<style>
    .settings-large { width: 900px; height: 80vh; }
    .settings-grid { display: grid; grid-template-columns: 280px 1fr; gap: 20px; height: 100%; overflow: hidden; }
    .settings-nav { border-right: 1px solid var(--border-color); padding-right: 15px; overflow-y: auto; }
    .settings-content { display: flex; flex-direction: column; overflow: hidden; }
    .header-with-action { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
    .model-list { display: flex; flex-direction: column; gap: 8px; max-height: 200px; overflow-y: auto; border: 1px solid var(--border-color); padding: 5px; border-radius: 4px; background: var(--input-bg-color); }
    .model-card { padding: 8px; border: 1px solid var(--border-color); border-radius: 4px; cursor: pointer; }
    .model-card:hover { background: var(--hover-bg-color); }
    .model-card.selected { border-color: var(--accent-color); background: var(--hover-bg-color); }
    .model-card-header { display: flex; justify-content: space-between; align-items: center; }
    .model-card-meta { font-size: 11px; color: var(--text-color-light); }
    .model-editor { margin-top: 15px; padding-top: 15px; border-top: 2px solid var(--border-color); overflow-y: auto; flex: 1; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    h5 { margin-top: 0; color: var(--accent-color); }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private Guid? _selectedModelId;
    private AiModelConfig? SelectedModel => AppState.AiModels.FirstOrDefault(m => m.Id == _selectedModelId);

    private void AddNewModel()
    {
        var model = new AiModelConfig { FriendlyName = "Új OpenAI kompatibilis" };
        AppState.AiModels.Add(model);
        _selectedModelId = model.Id;
    }

    private void RemoveModel(AiModelConfig model)
    {
        if (_selectedModelId == model.Id) _selectedModelId = null;
        AppState.AiModels.Remove(model);
    }

    private async Task SaveChanges()
    {
        var settings = new Settings
        {
            Theme = AppState.Theme,
            AiModels = AppState.AiModels.ToList(),
            GitSuggestionModelId = AppState.GitSuggestionModelId,
            ChatModelId = AppState.ChatModelId,
            AgentModelId = AppState.AgentModelId,
            OllamaApiUrl = AppState.OllamaApiUrl,
            OllamaModel = AppState.OllamaModel,
            OllamaShowThinking = AppState.OllamaShowThinking,
            AzureDevOpsOrganizationUrl = AppState.AzureDevOpsOrganizationUrl,
            AzureDevOpsProject = AppState.AzureDevOpsProject,
            AzureDevOpsPat = AppState.AzureDevOpsPat,
            BuildCommand = AppState.DefaultBuildCommand,
            RunCommand = AppState.DefaultRunCommand,
            LogInformationLevel = AppState.LogInformationLevel
        };
        await SettingsService.SaveSettingsAsync(settings);
        AppState.StatusText = "Beállítások és modellek mentve.";
        await Close();
    }

    private async Task Close() => await OnClose.InvokeAsync();
}