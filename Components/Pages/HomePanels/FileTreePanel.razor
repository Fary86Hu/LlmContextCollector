<div class="panel panel-left">
    <div class="toolbar">
        <button @onclick="SelectProjectFolder" disabled="@(AppState.CurrentBuildStatus == BuildStatus.Running)" title="@(AppState.CurrentBuildStatus == BuildStatus.Running ? "Futtatás alatt nem váltható projekt" : "")">Projekt Mappa...</button>
        <div class="custom-dropdown-container project-dropdown">
            <div class="custom-dropdown-trigger" @onclick="ToggleProjectDropdown" disabled="@(AppState.CurrentBuildStatus == BuildStatus.Running)">
                <span class="truncate">@(string.IsNullOrEmpty(AppState.ProjectRoot) ? "Nincs mappa kiválasztva" : AppState.ProjectRoot)</span>
                <span class="dropdown-arrow">▼</span>
            </div>
            @if (_isProjectDropdownOpen && AppState.CurrentBuildStatus != BuildStatus.Running)
            {
                <div class="custom-dropdown-list project-dropdown-list">
                    @if (string.IsNullOrEmpty(AppState.ProjectRoot))
                    {
                        <div class="custom-dropdown-item disabled">Nincs mappa kiválasztva</div>
                    }
                    @foreach (var folder in GetProjectFolders())
                    {
                        <div class="custom-dropdown-item @(folder == AppState.ProjectRoot ? "active" : "")" @onclick="() => SelectRecentProject(folder)">
                            <span class="item-text" title="@folder">@folder</span>
                            <button class="delete-project-btn" @onclick:stopPropagation="true" @onclick="() => DeleteProjectHistory(folder)" title="Mappa és összes előzményének törlése">🗑️</button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
    <div class="toolbar">
        @if (AppState.IsGitRepository && AppState.AvailableGitBranches.Any())
        {
            <div class="branch-group">
                <select class="branch-selector" value="@AppState.CurrentGitBranch" @onchange="HandleBranchChange" title="Branch váltás">
                    @foreach (var branch in AppState.AvailableGitBranches)
                    {
                        <option value="@branch">@branch</option>
                    }
                </select>
                <button class="icon-btn" @onclick="HandleGitPull" title="Git Pull (Frissítés)">📥</button>
                <button class="icon-btn" @onclick="ToggleMergeDropdown" title="Beolvasztás (Merge)">🔀</button>
            </div>
        }
    </div>
    @if (_showMergeDropdown && AppState.AvailableGitBranches.Any())
    {
        <div class="toolbar merge-branch-selector-bar">
            <span style="font-size: 11px;">Melyik ágat akarod beolvasztani?</span>
            <select class="branch-selector-merge" @bind="_branchToMerge">
                <option value="">-- válassz ágat --</option>
                @foreach (var branch in AppState.AvailableGitBranches.Where(b => b != AppState.CurrentGitBranch))
                {
                    <option value="@branch">@branch</option>
                }
            </select>
            <button class="primary btn-small" @onclick="StartBranchMerge" disabled="@(string.IsNullOrEmpty(_branchToMerge))">Indítás</button>
        </div>
    }

    <div class="toolbar panel-switcher-tabs">
        <div class="tab-item @(!AppState.LeftPanelShowAdo ? "active" : "")" @onclick="() => AppState.LeftPanelShowAdo = false">Fájlrendszer</div>
        <div class="tab-item @(AppState.LeftPanelShowAdo ? "active" : "")" @onclick="() => AppState.LeftPanelShowAdo = true">Azure DevOps</div>
    </div>

    @if (!AppState.LeftPanelShowAdo)
    {
        <div class="toolbar">
            <label for="history-select" style="white-space: nowrap; margin-right: 5px;">Előzmények:</label>
            <select id="history-select" @onchange="LoadSelectedHistory" style="flex-grow: 1;" disabled="@(AppState.CurrentBuildStatus == BuildStatus.Running)">
                <option value="" selected>Válassz egy előzményt...</option>
                @foreach (var entry in AppState.HistoryEntries.Where(e => e.RootFolder == AppState.ProjectRoot))
                {
                    <option value="@entry.Id">@FormatHistoryEntry(entry)</option>
                }
            </select>
        </div>
        <div class="toolbar">
            <input type="text" placeholder="Keresés..." style="flex-grow: 1;" @bind="AppState.SearchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyup" list="tree-search-history-list" />
            <datalist id="tree-search-history-list">
                @foreach (var term in AppState.TreeSearchHistory)
                {
                    <option value="@term"></option>
                }
            </datalist>
            <label style="font-size: 0.8em; margin: 0 5px;"><input type="checkbox" @bind="AppState.SearchInContent" /> Tartalomban</label>
            <button @onclick="ToggleFilter" 
                    disabled="@(string.IsNullOrWhiteSpace(AppState.SearchTerm) && !_isFiltered)" 
                    class="icon-btn" 
                    title="@(_isFiltered ? "Szűrés törlése" : "Szűrés")">
                @if (_isFiltered)
                {
                    <span>🚫</span>
                }
                else
                {
                    <svg viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M2 3h20l-8 9.46V19l-4 2v-8.54L2 3z"></path>
                    </svg>
                }
            </button>
            <button @onclick="FindPrevious" class="icon-btn" disabled="@(string.IsNullOrWhiteSpace(AppState.SearchTerm))" title="Előző találat">▲</button>
            <button @onclick="() => FindNext(false)" class="icon-btn" disabled="@(string.IsNullOrWhiteSpace(AppState.SearchTerm))" title="Következő találat">▼</button>
            <button @onclick="ClearSearch" class="icon-btn clear-btn" title="Törlés">&times;</button>
        </div>
        <div class="tree-view-container" @oncontextmenu="e => OnShowTreeContextMenu.InvokeAsync((null, e))" @oncontextmenu:preventDefault>
            @if (AppState.FileTree.Any())
            {
                foreach (var node in AppState.FileTree)
                {
                    <FileTreeNodeView Node="node" OnNodeClick="HandleNodeClick" OnNodeContextMenu="e => OnShowTreeContextMenu.InvokeAsync(e)" />
                }
            }
            else
            {
                <div style="padding: 10px; color: #888;">Nincs megjeleníthető fájl. Válasszon mappát és alkalmazza a szűrőket.</div>
            }
        </div>
        <LlmContextCollector.Components.Pages.HomePanels.ProjectActionFooter OnReload="OnRequestApplyFiltersAndReload" />
    }
    else
    {
        <AzureDevOpsPanel />
    }
</div>