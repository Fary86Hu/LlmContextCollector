@using LlmContextCollector.Models
@using LlmContextCollector.Services
@using System.ComponentModel
@inject AppState AppState
@inject BrowserService BrowserService
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="panel panel-right workbench-container">
    <div class="workbench-content">
        <ChatTab OnApplyResponse="RouteResponseAsync" />
    </div>
</div>

@code {
    private ContextTab? _contextTab;

    [Parameter] public EventCallback<MouseEventArgs> OnShowListContextMenu { get; set; }
    [Parameter] public List<string> SelectedItems { get; set; } = new();
    [Parameter] public EventCallback<List<string>> SelectedItemsChanged { get; set; }
    [Parameter] public EventCallback OnShowPromptManager { get; set; }
    [Parameter] public EventCallback OnShowSettingsDialog { get; set; }
    [Parameter] public EventCallback<DiffResultArgs> OnShowDiffDialog { get; set; }
    [Parameter] public EventCallback OnAddSelectedToContext { get; set; }
    [Parameter] public EventCallback OnExcludeSelectedFromTree { get; set; }
    [Parameter] public EventCallback OnRequestRemoveSelected { get; set; }
    [Parameter] public EventCallback OnHistorySaveRequested { get; set; }
    [Parameter] public EventCallback<(MouseEventArgs, string)> OnSplitterMouseDown { get; set; }
    [Parameter] public EventCallback<DiffResultArgs> OnRequestLocalizationPath { get; set; }

    protected override void OnInitialized()
    {
        BrowserService.OnContentExtracted += HandleBrowserContentExtracted;
        AppState.PropertyChanged += HandleAppStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ApplyTheme();
        }
    }

    private async void HandleAppStateChanged(object? sender, PropertyChangedEventArgs e)
    {
        if (e.PropertyName == nameof(AppState.Theme))
        {
            await InvokeAsync(ApplyTheme);
        }
    }

    private async Task ApplyTheme()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("setTheme", AppState.Theme);
        }
        catch { }
    }

    private async Task HandleBrowserContentExtracted(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return;
        
        BrowserService.CloseBrowser();
        
        await RouteResponseAsync(content);
    }

    public async Task UpdatePreview(string? path = null, List<string>? items = null)
    {
        if (_contextTab != null) await _contextTab.UpdatePreview(path, items);
    }

    public async Task ScrollToPath(string relPath)
    {
        if (_contextTab != null) await _contextTab.ScrollToPath(relPath);
    }

    public async Task SearchInPreview(string term)
    {
        if (_contextTab != null) await _contextTab.SearchInPreview(term);
    }

    public void CloseCustomDropdowns()
    {
        _contextTab?.CloseCustomDropdowns();
    }

    public async Task RouteResponseAsync(string content)
    {
        AppState.RequestWorkbenchFocus(WorkbenchTab.Context);
        await Task.Yield();
        StateHasChanged();
        await Task.Delay(100);
        if (_contextTab != null)
        {
            await _contextTab.RouteResponseAsync(content);
        }
    }

    public void Dispose()
    {
        BrowserService.OnContentExtracted -= HandleBrowserContentExtracted;
        AppState.PropertyChanged -= HandleAppStateChanged;
    }
}