@using LlmContextCollector.Services
@using LlmContextCollector.AI
@using System.Text
@inject ChatService ChatService
@inject IJSRuntime JSRuntime
@inject AppState AppState
@inject PromptService PromptService
@inject ContextProcessingService ContextProcessingService
@implements IDisposable

<div class="chat-main-layout">
    <div class="chat-sidebar">
        <button class="primary new-chat-btn" @onclick="ChatService.CreateNewSessionAsync">+ Új Chat</button>
        <div class="session-list">
            @foreach (var session in ChatService.Sessions)
            {
                <div class="session-item @(ChatService.CurrentSessionId == session.Id ? "active" : "")" @onclick="() => ChatService.SwitchToSessionAsync(session.Id)">
                    <span class="session-title" title="@session.Title">@session.Title</span>
                    <button class="delete-session-btn" @onclick="() => ChatService.DeleteSessionAsync(session.Id)" @onclick:stopPropagation>🗑</button>
                </div>
            }
        </div>
    </div>

    <div class="chat-tab-container">
        <div class="chat-header-actions">
            <div class="chat-model-selector">
                <select @bind="AppState.ChatModelId">
                    <option value="@Guid.Empty">Lokális Ollama (Streaming)</option>
                    @foreach (var model in AppState.AiModels)
                    {
                        <option value="@model.Id">@model.FriendlyName</option>
                    }
                </select>
                <label title="Gondolatmenet mutatása/elrejtése">
                    <input type="checkbox" @bind="AppState.OllamaShowThinking" /> Thinking
                </label>
            </div>
        </div>
        <div class="chat-messages-area" id="chat-tab-messages">
            @foreach (var msg in ChatService.Messages)
            {
                @if (msg.Role == "system")
                {
                    <details class="system-context-details">
                        <summary>Rendszer Prompt és Kontextus</summary>
                        <div class="message-content system-message-content">@((MarkupString)GetFormattedResponse(msg.Content, false))</div>
                    </details>
                }
                else
                {
                    <div class="chat-message @(msg.Role)">
                        <div class="message-header">
                            <strong>@(msg.Role == "user" ? "Te" : "AI"):</strong>
                            @if (msg.Role == "assistant" && !ChatService.IsGenerating)
                            {
                                <button class="apply-btn" @onclick="() => OnApplyResponse.InvokeAsync(msg.Content)">Alkalmazás</button>
                            }
                        </div>
                        <div class="message-content">@((MarkupString)GetFormattedResponse(msg.Content, false))</div>
                    </div>
                }
            }
            @if (ChatService.IsGenerating)
            {
                <div class="chat-message assistant generating">
                    <strong>AI:</strong>
                    <div class="message-content">@((MarkupString)GetFormattedResponse(ChatService.CurrentResponseSnippet, true))</div>
                </div>
            }
        </div>

        <div class="chat-input-area">
            <div class="chat-input-wrapper">
                <textarea id="chat-tab-input"
                          class="chat-input" 
                          @bind="_currentInput" 
                          @bind:event="oninput" 
                          @onkeydown="HandleKeyDown" 
                          placeholder="Írj egy üzenetet... (Shift+Enter új sor, Enter küldés)"></textarea>
                <div class="chat-stats-bar">
                    <span>@AppState.ChatCharCount.ToString("N0") karakter</span>
                    <span>~@AppState.ChatTokenCount.ToString("N0") token</span>
                </div>
            </div>
            <div class="input-actions">
                @if (ChatService.IsGenerating)
                {
                    <button class="abort-btn" @onclick="ChatService.Abort">Stop</button>
                }
                else
                {
                    <button class="primary send-btn" @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(_currentInput))">Küldés</button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback<string> OnApplyResponse { get; set; }

    private string _currentInput = string.Empty;
    protected override async Task OnInitializedAsync()
    {
        AppState.PropertyChanged += HandleAppStateChanged;
        await ChatService.LoadSessionsAsync();
    }
    private async void HandleAppStateChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        try
        {
            if (e.PropertyName == nameof(AppState.ProjectRoot))
            {
                await ChatService.LoadSessionsAsync();
            }
            if (e.PropertyName == nameof(AppState.OllamaShowThinking) ||
                e.PropertyName == nameof(AppState.ChatModelId) ||
                e.PropertyName == nameof(ChatService.IsGenerating) ||
                e.PropertyName == "CurrentResponseSnippet" ||
                e.PropertyName == "Messages" ||
                e.PropertyName == "Sessions")
            {
                await InvokeAsync(StateHasChanged);
                await ScrollToBottom();
            }
        }
        catch (Exception ex)
        {
            AppState.StatusText = $"Hiba a chat betoltesekor: {ex.Message}";
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
        else
        {
            await UpdateChatStats();
        }
    }
    private async Task UpdateChatStats()
    {
        var fullContext = await ContextProcessingService.BuildContextForClipboardAsync(
            AppState.ChatIncludePrompt, 
            AppState.ChatIncludeSystem, 
            AppState.ChatIncludeFiles, 
            AppState.IncludeProjectTreeInCopy,
            AppState.SelectedFilesForContext);

        var totalChars = _currentInput.Length + (string.IsNullOrEmpty(fullContext) ? 0 : fullContext.Length);
        
        AppState.ChatCharCount = totalChars;
        AppState.ChatTokenCount = totalChars / 4;
        StateHasChanged();
    }
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_currentInput) || ChatService.IsGenerating) return;
        var input = _currentInput;
        _currentInput = string.Empty;

        var system = await PromptService.GetSystemPromptAsync();
        var files = await ContextProcessingService.BuildContextForClipboardAsync(false, false, true, false, AppState.SelectedFilesForContext);

        await ChatService.SendMessageAsync(input, system, files, forceRefreshContext: AppState.IsContextDirty);
        await UpdateChatStats();
    }
    private string GetFormattedResponse(string rawText, bool isGenerating)
    {
        if (string.IsNullOrWhiteSpace(rawText)) return isGenerating ? "<span class=\"cursor-blink\">|</span>" : string.Empty;

        string text = rawText;
        if (!AppState.OllamaShowThinking)
        {
            while (text.Contains("<think>"))
            {
                int start = text.IndexOf("<think>");
                int end = text.IndexOf("</think>");
                if (end != -1) text = text.Remove(start, (end + 8) - start);
                else text = text.Substring(0, start);
            }
        }

        var blocks = new List<(string Content, bool IsCode)>();
        var remainingText = text;
        var codeRegex = new System.Text.RegularExpressions.Regex("```([\\s\\S]*?)```");
        var matches = codeRegex.Matches(remainingText);
        int lastIndex = 0;

        foreach (System.Text.RegularExpressions.Match match in matches)
        {
            if (match.Index > lastIndex)
            {
                blocks.Add((remainingText.Substring(lastIndex, match.Index - lastIndex), false));
            }
            blocks.Add((match.Groups[1].Value, true));
            lastIndex = match.Index + match.Length;
        }

        if (lastIndex < remainingText.Length)
        {
            blocks.Add((remainingText.Substring(lastIndex), false));
        }

        var sb = new StringBuilder();
        foreach (var block in blocks)
        {
            if (block.IsCode)
            {
                var codeLines = block.Content.Split('\n');
                var firstLine = codeLines.FirstOrDefault()?.Trim();
                var rawCode = block.Content;
                if (!string.IsNullOrEmpty(firstLine) && (firstLine == "csharp" || firstLine == "cs" || firstLine == "json" || firstLine == "xml" || firstLine == "javascript" || firstLine == "js" || firstLine == "css" || firstLine == "html"))
                {
                    rawCode = string.Join("\n", codeLines.Skip(1));
                }
                var escapedCode = System.Web.HttpUtility.HtmlEncode(rawCode.Trim());
                sb.Append($"<pre class=\"chat-code-block\"><code>{escapedCode}</code></pre>");
            }
            else
            {
                var escapedText = System.Web.HttpUtility.HtmlEncode(block.Content);
                escapedText = System.Text.RegularExpressions.Regex.Replace(escapedText, "\\*\\*(.*?)\\*\\*", "<strong>$1</strong>");
                escapedText = escapedText.Replace("&lt;think&gt;", "<div class=\"thinking-block\">").Replace("&lt;/think&gt;", "</div>");
                escapedText = escapedText.Replace("\n", "<br />");
                sb.Append(escapedText);
            }
        }

        var displayHtml = sb.ToString();
        if (isGenerating) displayHtml += "<span class=\"cursor-blink\">|</span>";

        return displayHtml;
    }
    private async Task ScrollToBottom()
    {
        try { await JSRuntime.InvokeVoidAsync("scrollToBottom", "chat-tab-messages"); } catch { }
    }
    public void Dispose() => AppState.PropertyChanged -= HandleAppStateChanged;
}