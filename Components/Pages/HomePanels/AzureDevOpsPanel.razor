@using LlmContextCollector.Models
@using LlmContextCollector.Services
@inject AppState AppState
@inject AzureDevOpsService AdoService
@inject AppLogService LogService

<div class="ado-panel">
    <div class="ado-filters">
        <div class="filter-group">
            <label class="group-label">Státuszok:</label>
            <div class="selection-chips">
                @foreach (var status in _availableStatuses)
                {
                    <div class="chip @(_selectedStatuses.Contains(status) ? "active" : "")" @onclick="() => ToggleStatus(status)">
                        @status
                    </div>
                }
            </div>
        </div>

        <div class="filter-group">
            <label class="group-label">Felelősök:</label>
            <div class="selection-chips members-chips">
                <div class="chip @(_selectedAssignees.Contains("@Me") ? "active" : "")" @onclick="@(() => ToggleAssignee("@Me"))">
                    @("@Me")
                </div>
                @foreach (var member in _projectMembers)
                {
                    <div class="chip @(_selectedAssignees.Contains(member.DisplayName) ? "active" : "")" @onclick="() => ToggleAssignee(member.DisplayName)">
                        @member.DisplayName
                    </div>
                }
                @if (!_projectMembers.Any() && !_isLoadingMembers)
                {
                    <span class="hint-text">Tagok betöltése folyamatban...</span>
                }
            </div>
        </div>

        <div class="filter-group">
            <label class="group-label">További szűrők:</label>
            <div style="display: flex; flex-direction: column; gap: 6px; padding: 2px;">
                <label style="display: flex; align-items: center; gap: 6px; cursor: pointer; font-size: 11px;">
                    <input type="checkbox" @bind="AppState.AdoDownloadOnlyMine" style="width: auto; margin: 0;" />
                    A kiválasztott felelősök által lezárt vagy feloldott (Resolved/Closed) elemek is
                </label>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span style="font-size: 11px;">Módosítva óta:</span>
                    <input type="date" value="@AppState.AdoMinChangedDate?.ToString("yyyy-MM-dd")" @onchange="OnMinDateChanged" style="height: 24px; font-size: 11px; flex: 1; padding: 2px;" />
                </div>
            </div>
        </div>

        <div class="filter-row">
            <label>Típus:</label>
            <select @bind="_selectedType">
                <option value="">Összes</option>
                <option value="User Story">User Story</option>
                <option value="Task">Task</option>
                <option value="Bug">Bug</option>
            </select>
            <button class="primary load-btn" @onclick="LoadWorkItems" disabled="@_isLoading">
                @if (_isLoading) { <span class="spinner-mini"></span> }
                <span>Keresés</span>
            </button>
            <button class="secondary load-btn" @onclick="DownloadAllWorkItems" disabled="@_isLoading" title="Összes munkaelem letöltése offline kontextusként">
                @if (_isLoading) { <span class="spinner-mini"></span> }
                <span>Letöltés</span>
            </button>
        </div>
    </div>

    <div class="ado-list-container">
        @if (_workItems.Any())
        {
            <div class="ado-list">
                @foreach (var item in _workItems)
                {
                    <div class="ado-item" @onclick="() => SelectWorkItem(item.Id)">
                        <div class="item-header">
                            <span class="item-id">#@item.Id</span>
                            <span class="item-type @item.Type.ToLower().Replace(" ", "-")">@item.Type</span>
                            <span class="item-state">@item.State</span>
                        </div>
                        <div class="item-title">@item.Title</div>
                        <div class="item-assignee">👤 @item.AssignedTo</div>
                    </div>
                }
            </div>
        }
        else if (!_isLoading)
        {
            <div class="empty-state">Nincs találat. Állíts be szűrőket és keress.</div>
        }
    </div>
</div>