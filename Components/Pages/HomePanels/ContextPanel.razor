<div class="panel panel-right" style="--right-top-flex:@(AppState.RightTopPanelFlex.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)); --right-middle-flex:@(AppState.RightMiddlePanelFlex.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)); --right-bottom-flex:@(AppState.RightBottomPanelFlex.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));">
    
    <div class="right-top-section">
        <div class="toolbar" style="align-items: center;">
            <label style="margin-right: 5px;">Globális Prompt:</label>
            <div class="custom-dropdown-container" style="flex-grow: 1;">
                <div class="custom-dropdown-trigger" @onclick="ToggleTopDropdown" @onclick:stopPropagation="true">
                    <span>@(AppState.PromptTemplates.FirstOrDefault(p => p.Id == AppState.ActiveGlobalPromptId)?.Title ?? "Válassz...")</span>
                    <span class="dropdown-arrow">▼</span>
                </div>
                @if (_isTopDropdownOpen)
                {
                    <div class="custom-dropdown-list">
                        @foreach (var prompt in AppState.PromptTemplates)
                        {
                            <div class="custom-dropdown-item @(prompt.Id == AppState.ActiveGlobalPromptId ? "active" : "")" @onclick="() => SelectTopPrompt(prompt.Id)">
                                <span class="item-text">@prompt.Title</span>
                                <button class="copy-item-btn" @onclick:stopPropagation="true" @onclick="() => CopyTemplateById(prompt.Id)" title="Csak a sablon tartalmának másolása">
                                    📋
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
            <button @onclick="OnShowPromptManager">Szerkesztés...</button>
            
            <div class="ado-quick-load" style="display: flex; align-items: center; margin-left: 10px; gap: 2px;">
                <input type="number" placeholder="ADO ID..." @bind="_adoWorkItemIdToLoad" style="width: 80px; height: 30px;" @onkeyup="HandleAdoKeyup" />
                <button @onclick="LoadAdoWorkItemAsync" title="ADO Work Item betöltése a promptba" style="height: 30px; padding: 0 8px;">Betölt</button>
            </div>

            <button @onclick="() => AppState.IsAiInspectorVisible = true" title="Rendszernapló és AI Inspector" style="margin: 0 5px;">📜</button>
            <button @onclick="OnShowSettingsDialog" title="Beállítások" style="margin: 0 0 0 5px;">⚙️</button>
        </div>
        <div class="prompt-container">
            <textarea class="prompt-editor" placeholder="Írja ide a promptot..." @bind="AppState.PromptText" @bind:event="oninput"></textarea>
            <div class="prompt-editor-button-group">
                <button class="prompt-editor-btn" @onclick="PickImagesAsync" title="Képek csatolása">🖼️</button>
                @if (!string.IsNullOrWhiteSpace(AppState.PromptText) || AppState.AttachedImages.Any())
                {
                    <button class="prompt-editor-btn" @onclick="ClearPrompt" title="Prompt és képek törlése">&times;</button>
                }
            </div>
        </div>
        @if (AppState.AttachedImages.Any())
        {
            <div class="attached-images-strip">
                <div class="attached-images-info">
                    <button class="icon-btn-small" @onclick="CopyImagesAsync" title="Képek vágólapra másolása (Ctrl+B)">📋 (Ctrl+B)</button>
                </div>
                @foreach (var img in AppState.AttachedImages)
                {
                    <div class="image-thumbnail" title="@img.FileName">
                        <img src="@img.Base64Thumbnail" />
                        <button class="remove-img-btn" @onclick="() => AppState.AttachedImages.Remove(img)">&times;</button>
                    </div>
                }
            </div>
        }
    </div>

    <div class="horizontal-splitter" @onmousedown='e => OnSplitterMouseDown.InvokeAsync((e, "RightTop"))'></div>

    <div class="right-middle-section">
        <div class="context-list-header">
            <h4>Kiválasztott Fájlok (Kontextushoz)</h4>
            <div class="preview-search-controls">
                <input type="text" 
                       placeholder="Szűrés..." 
                       @bind="_contextSearchTerm" 
                       @bind:event="oninput" 
                       @onkeyup="HandleContextSearchKeyup" />
                <button @onclick="ClearContextSearch" disabled="@(string.IsNullOrEmpty(_contextSearchTerm))" class="clear-btn">&times;</button>
            </div>
        </div>
        <div class="context-table-container" @onkeydown="HandleListKeyDown" tabindex="0">
            <table class="context-table">
                <thead>
                    <tr>
                        <th class="sortable @GetSortClass("path")" @onclick='() => SortBy("path")'>Elérési út</th>
                        <th class="sortable @GetSortClass("name")" @onclick='() => SortBy("name")'>Fájlnév</th>
                        <th class="sortable @GetSortClass("size")" @onclick='() => SortBy("size")'>Méret</th>
                        <th>Műveletek</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var fileInfo in _sortedFiles)
                    {
                        <tr @key="fileInfo.RelativePath"
                            class="@(SelectedItems.Contains(fileInfo.RelativePath) ? "selected" : "")"
                            @onclick="(e) => OnFileRowClick(e, fileInfo.RelativePath)"
                            @oncontextmenu="(e) => ShowContextMenuForRow(e, fileInfo.RelativePath)" @oncontextmenu:preventDefault>
                            <td>
                                @if (fileInfo.RelativePath.StartsWith("[ORIGINAL]"))
                                {
                                    <span class="ref-badge ref-original" title="A fájl eredeti verziója a merge-base ágról.">ORIG</span>
                                }
                                @fileInfo.DisplayPath
                            </td>
                            <td>@fileInfo.FileName</td>
                            <td style="text-align: right;">@fileInfo.Size.ToString("N0")</td>
                            <td class="actions-cell" @onclick:stopPropagation>
                                <button class="icon-btn-small" title="Referenciák hozzáadása (1 mélység)" @onclick="() => OnAddReferencesClick(fileInfo.RelativePath)">🔗</button>
                                <button class="icon-btn-small" title="Hivatkozó fájlok hozzáadása" @onclick="() => OnAddReferencingClick(fileInfo.RelativePath)">👈</button>
                                <button class="icon-btn-small delete-btn" title="Törlés a listából" @onclick="() => OnRemoveItemClick(fileInfo.RelativePath)">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="toolbar">
            <button title="Visszavonás" @onclick="AppState.UndoContextListChange" disabled="@(!AppState.CanUndo)">⮌</button>
            <button title="Újra" @onclick="AppState.RedoContextListChange" disabled="@(!AppState.CanRedo)">⮍</button>
        
            <button style="margin: 0 5px;" @onclick="OnShowDocumentSearchDialog" disabled="@(AppState.IsSemanticIndexBuilding || !IsIndexReady)">Keresés</button>
            <button style="margin: 0 5px;" @onclick="GitWorkflowService.AddOriginalModifiedFilesToContextAsync" disabled="@(!AppState.IsGitRepository)" title="A branch nyitása óta módosított fájlok eredeti verziójának hozzáadása">Eredetiek</button>
        
            <span style="margin-left:auto;"></span>
            <span class="char-counter">@_charCount.ToString("N0") kar.</span>
            <span class="char-counter">~@_tokenCount.ToString("N0") tok.</span>
            <button @onclick="ClearSelectionList">Lista ürítése</button>
        </div>
    </div>

    <div class="horizontal-splitter" @onmousedown='e => OnSplitterMouseDown.InvokeAsync((e, "RightMiddle"))'></div>

    <div class="right-bottom-section">
        <div class="preview-header">
            <h4>Fájl Előnézet</h4>
            <div class="preview-search-controls">
                <div class="ref-toggle" title="Referenciák megjelenítése/elrejtése. Zöld: Kontextusban, Kék: Nincs kontextusban.">
                    <input type="checkbox" id="chk-refs" checked="@_showReferences" @onchange="ToggleReferences" />
                    <label for="chk-refs">Ref.</label>
                </div>
                
                <input type="text" 
                       placeholder="Keresés..." 
                       @bind="_previewSearchTerm" 
                       @bind:event="oninput" 
                       @onkeyup="HandlePreviewSearchKeyup" 
                       disabled="@_showReferences" />
                @if (_totalPreviewMatches > 0)
                {
                    <span class="preview-match-counter">@_currentPreviewMatchIndex/@_totalPreviewMatches</span>
                }
                <button @onclick="FindPreviousInPreview" disabled="@(_totalPreviewMatches == 0 || _showReferences)" title="Előző">▲</button>
                <button @onclick="FindNextInPreview" disabled="@(_totalPreviewMatches == 0 || _showReferences)" title="Következő">▼</button>
                <button @onclick="ClearPreviewSearch" disabled="@(string.IsNullOrEmpty(_previewSearchTerm))" class="clear-btn">&times;</button>
            </div>
        </div>
        <div id="preview-box" class="preview-box">
            <pre>@_previewContentMarkup</pre>
        </div>
    </div>
    
    <script>
        window.initializePreviewInteractions = (dotNetObj) => {
            const box = document.getElementById('preview-box');
            if(box) {
                box.addEventListener('click', (e) => {
                    const target = e.target.closest('.ref-badge');
                    if (target && target.dataset.typeName) {
                        e.preventDefault();
                        e.stopPropagation();
                        dotNetObj.invokeMethodAsync('OnReferenceClicked', target.dataset.typeName);
                    }
                });
            }

            window.addEventListener('keydown', (e) => {
                if (e.ctrlKey && e.key.toLowerCase() === 'b') {
                    e.preventDefault();
                    dotNetObj.invokeMethodAsync('OnCtrlB_Pressed');
                }
            });

            window.addEventListener('paste', (e) => {
                const items = (e.clipboardData || window.clipboardData).items;
                for (let i = 0; i < items.length; i++) {
                    if (items[i].type.indexOf('image') !== -1) {
                        const file = items[i].getAsFile();
                        const reader = new FileReader();
                        reader.onload = function(event) {
                            dotNetObj.invokeMethodAsync('OnImagePastedAsync', event.target.result);
                        };
                        reader.readAsDataURL(file);
                    }
                }
            });
        };
    </script>

    <div class="bottom-actions">
        <div class="main-actions">
            <div class="copy-group">
                <div class="copy-options-inline">
                    <label title="Felhasználói prompt hozzáadása"><input type="checkbox" @bind="AppState.IncludePromptInCopy" />Prompt</label>
                    <label title="Rendszer utasítások hozzáadása"><input type="checkbox" @bind="AppState.IncludeSystemPromptInCopy" />System</label>
                    <label title="Kiválasztott fájlok tartalmának hozzáadása"><input type="checkbox" @bind="AppState.IncludeFilesInCopy" />Fájlok</label>
                    <label title="A projekt teljes látható fájllistájának hozzáadása"><input type="checkbox" @bind="AppState.IncludeProjectTreeInCopy" />Struktúra</label>
                </div>
                
                <div class="custom-dropdown-container inline-dropdown" style="margin: 0 8px; width: 150px;">
                    <div class="custom-dropdown-trigger" @onclick="ToggleDocsDropdown" @onclick:stopPropagation="true" style="width: 100%;">
                        <span>Dokumentumok (@AppState.AttachableDocuments.Count(d => d.IsSelected))</span>
                        <span class="dropdown-arrow">▼</span>
                    </div>
                    @if (_isDocsDropdownOpen)
                    {
                        <div class="custom-dropdown-list bottom-dropdown">
                            @foreach (var doc in AppState.AttachableDocuments)
                            {
                                <div class="custom-dropdown-item" @onclick="() => ToggleDocumentSelection(doc)" @onclick:stopPropagation="true">
                                    <input type="checkbox" checked="@doc.IsSelected" style="margin-right: 8px;" @onclick:stopPropagation="true" @onchange="e => { doc.IsSelected = (bool)(e.Value ?? false); _ = SaveProjectSettingsAsync(); }" />
                                    <span class="item-text">@doc.Title</span>
                                    <button class="icon-btn-small" @onclick="() => EditDocument(doc)" @onclick:stopPropagation="true" title="Szerkesztés">✏️</button>
                                </div>
                            }
                            <div class="custom-dropdown-item" style="justify-content: center; border-top: 1px solid var(--border-color); color: var(--accent-color); font-weight: bold;" @onclick="AddNewDocument" @onclick:stopPropagation="true">
                                + Új dokumentum
                            </div>
                        </div>
                    }
                </div>

                <div class="custom-dropdown-container inline-dropdown" style="margin: 0 8px 0 0; flex-grow: 1; max-width: 250px;">
                    <div class="custom-dropdown-trigger" @onclick="ToggleBottomDropdown" @onclick:stopPropagation="true" style="width: 160px;">
                        <span>@(AppState.PromptTemplates.FirstOrDefault(p => p.Id == AppState.ActiveGlobalPromptId)?.Title ?? "Válassz...")</span>
                        <span class="dropdown-arrow">▼</span>
                    </div>
                    @if (_isBottomDropdownOpen)
                    {
                        <div class="custom-dropdown-list bottom-dropdown">
                            @foreach (var prompt in AppState.PromptTemplates)
                            {
                                <div class="custom-dropdown-item @(prompt.Id == AppState.ActiveGlobalPromptId ? "active" : "")" @onclick="() => SelectBottomPrompt(prompt.Id)">
                                    <span class="item-text">@prompt.Title</span>
                                    <button class="copy-item-btn" @onclick:stopPropagation="true" @onclick="() => CopyTemplateById(prompt.Id)" title="Csak a sablon tartalmának másolása">
                                        📋
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
                <button class="copy-button primary" @onclick="CopyToClipboard" title="Vágólapra másolás (a pipáknak megfelelően)">@_copyButtonText</button>
            </div>
            
            <div class="other-actions">
                <button class="copy-button" @onclick="OpenAiStudioBrowser" title="AI Studio megnyitása belső böngészőben">🌐 AI Studio</button>
                <button class="copy-button" @onclick="ProcessWithLocalAiAsync" title="Lokális Ollama (Qwen3) hívása">🏠 Lokális AI</button>
                <button @onclick="ProcessGitDiffAsync" disabled="@(!AppState.IsGitRepository)">Git Diff</button>
                <button class="copy-button" @onclick="ProcessChangesFromClipboardAsync" title="Vágólap feldolgozása (Kérdés vagy Implementáció)">Feldolgoz</button>
            </div>
        </div>
    </div>
</div>

<ClarificationDialog IsVisible="_isClarificationDialogVisible" 
                     ClipboardText="@_clarificationDialogText" 
                     OnClose="OnClarificationDialogClose" 
                     OnGenerateRefinedPrompt="HandleGenerateRefinedPrompt" />