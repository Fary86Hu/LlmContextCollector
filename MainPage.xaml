<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:LlmContextCollector"
             x:Class="LlmContextCollector.MainPage"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <Grid>
        <!-- Eredeti Blazor App -->
        <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
            <BlazorWebView.RootComponents>
                <RootComponent Selector="#app" ComponentType="{x:Type local:Components.Routes}" />
            </BlazorWebView.RootComponents>
        </BlazorWebView>

        <!-- Natív Böngésző Overlay -->
        <Grid x:Name="BrowserOverlay" IsVisible="False" BackgroundColor="#F0F0F0" ZIndex="1000">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Böngésző -->
            <WebView x:Name="InternalBrowser" Grid.Row="0" BackgroundColor="White" />

            <!-- Custom Dropdown List (Floating UPWARDS from toolbar) -->
            <Frame x:Name="PickerDropdown" Grid.Row="0" IsVisible="False" Padding="0" Margin="235,0,0,5" 
                   BackgroundColor="White" BorderColor="#0078d4" HasShadow="True" ZIndex="2000" 
                   VerticalOptions="End" HorizontalOptions="Start" 
                   MaximumHeightRequest="350" WidthRequest="280">
                <CollectionView x:Name="TemplatesListView" SelectionMode="Single" SelectionChanged="TemplatesListView_SelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*, Auto" Padding="12,8">
                                <Label Text="{Binding Title}" FontSize="12" TextColor="Black" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="📋" Clicked="CopyTemplateItem_Clicked" 
                                        BackgroundColor="Transparent" TextColor="#0078d4" 
                                        HeightRequest="32" WidthRequest="32" Padding="0" FontSize="16" 
                                        VerticalOptions="Center" ToolTipProperties.Text="Sablon másolása" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Frame>

            <!-- Vezérlő Sáv -->
            <Grid Grid.Row="1" BackgroundColor="#E0E0E0" Padding="10" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Prompt Config Row -->
                <HorizontalStackLayout Grid.Row="0" Spacing="8" VerticalOptions="Center" HorizontalOptions="Start">
                    <!-- Prompt Checkbox -->
                    <Grid ColumnDefinitions="30,Auto" VerticalOptions="Center">
                        <CheckBox x:Name="PromptCheckBox" Grid.Column="0" IsChecked="True" Color="#0078d4" WidthRequest="30" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Prompt" VerticalOptions="Center" TextColor="#333" FontSize="12">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="PromptLabel_Tapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    
                    <!-- System Checkbox -->
                    <Grid ColumnDefinitions="30,Auto" VerticalOptions="Center">
                        <CheckBox x:Name="SystemPromptCheckBox" Grid.Column="0" IsChecked="True" Color="#0078d4" WidthRequest="30" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="System" VerticalOptions="Center" TextColor="#333" FontSize="12">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="SystemLabel_Tapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Files Checkbox -->
                    <Grid ColumnDefinitions="30,Auto" VerticalOptions="Center">
                        <CheckBox x:Name="FileContextCheckBox" Grid.Column="0" IsChecked="True" Color="#0078d4" WidthRequest="30" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Fájlok" VerticalOptions="Center" TextColor="#333" FontSize="12">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="FilesLabel_Tapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <!-- Tree Checkbox -->
                    <Grid ColumnDefinitions="30,Auto" VerticalOptions="Center">
                        <CheckBox x:Name="TreeContextCheckBox" Grid.Column="0" IsChecked="False" Color="#0078d4" WidthRequest="30" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Struktúra" VerticalOptions="Center" TextColor="#333" FontSize="12">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TreeLabel_Tapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                    <BoxView WidthRequest="1" HeightRequest="20" BackgroundColor="#CCC" VerticalOptions="Center" Margin="5,0" />

                    <Label Text="Sablon:" VerticalOptions="Center" TextColor="#333" FontSize="12" FontAttributes="Bold" />
                    
                    <!-- Custom Dropdown Trigger -->
                    <Grid VerticalOptions="Center" WidthRequest="200" Margin="0,0,5,0">
                        <Frame Padding="8,4" HeightRequest="32" BackgroundColor="#EEE" BorderColor="#CCC" HasShadow="False" CornerRadius="4">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TogglePicker_Tapped" />
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*, Auto">
                                <Label x:Name="SelectedTemplateLabel" Text="Válassz..." FontSize="12" TextColor="Black" VerticalOptions="Center" LineBreakMode="NoWrap" />
                                <Label Grid.Column="1" Text="▼" FontSize="8" TextColor="#666" VerticalOptions="Center" Margin="5,0,0,0" />
                            </Grid>
                        </Frame>
                    </Grid>

                    <BoxView WidthRequest="1" HeightRequest="20" BackgroundColor="#CCC" VerticalOptions="Center" Margin="5,0" />

                    <Button x:Name="CopyButton" Text="Másolás" Clicked="CopyContext_Clicked" BackgroundColor="#0078d4" TextColor="White" HeightRequest="34" Padding="15,0" FontSize="12" FontAttributes="Bold" VerticalOptions="Center" Margin="10,0,0,0" />
                </HorizontalStackLayout>

                <!-- Prompt Editor Row -->
                <Editor x:Name="PromptEditor" Grid.Row="1" HeightRequest="60" MaximumHeightRequest="120" BackgroundColor="White" TextColor="Black" FontSize="12" AutoSize="TextChanges" Placeholder="Prompt szövege..." />

                <!-- Action Buttons Row -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,5,0,0">
                    <Button Grid.Column="0" Text="Bezárás" Clicked="CloseBrowser_Clicked" BackgroundColor="#666" TextColor="White" HeightRequest="36" FontSize="12" WidthRequest="80" />
                    <Label Grid.Column="1" Text="Illeszd be a vágólap tartalmát az AI-nak, majd a válasz után kattints a Feldolgozásra." 
                           VerticalOptions="Center" TextColor="#333" FontSize="11" LineBreakMode="WordWrap" HorizontalTextAlignment="Center" />
                    <Button Grid.Column="2" Text="Feldolgozás" Clicked="ExtractBrowser_Clicked" BackgroundColor="#28a745" TextColor="White" HeightRequest="36" FontAttributes="Bold" FontSize="12" WidthRequest="100" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>