<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:LlmContextCollector"
             x:Class="LlmContextCollector.MainPage"
             BackgroundColor="{DynamicResource PageBackgroundColor}">

    <ContentPage.Resources>
        <Style TargetType="Button" x:Key="TabBtn">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="#9e9e9e" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HeightRequest" Value="32" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
    </ContentPage.Resources>

    <Grid x:Name="MainRootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="BlazorColumn" Width="0.7*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition x:Name="AiColumn" Width="0.3*" />
        </Grid.ColumnDefinitions>

        <!-- OSZLOP 0: Fő Blazor UI (FileTree + Context) -->
        <BlazorWebView Grid.Column="0" HostPage="wwwroot/index.html">
            <BlazorWebView.RootComponents>
                <RootComponent Selector="#app" ComponentType="{x:Type local:Components.Routes}" />
            </BlazorWebView.RootComponents>
        </BlazorWebView>

        <!-- OSZLOP 1: Natív Splitter -->
        <BoxView Grid.Column="1" BackgroundColor="#555555" HorizontalOptions="Fill">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="BackgroundColor" Value="#0090ff" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </VisualStateManager.VisualStateGroups>
            <BoxView.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnSplitterPanUpdated" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- OSZLOP 2: Natív AI Workspace -->
        <Grid Grid.Column="2" RowDefinitions="Auto, *">
            <HorizontalStackLayout Grid.Row="0" BackgroundColor="#3c3c3c" Padding="5" Spacing="2">
                <Button x:Name="TabChatBtn" Text="Chat" Clicked="OnTabClicked" Style="{StaticResource TabBtn}" CommandParameter="Chat" />
                <Button x:Name="TabStudioBtn" Text="AI Studio" Clicked="OnTabClicked" Style="{StaticResource TabBtn}" CommandParameter="Studio" />
                <Button x:Name="TabLogsBtn" Text="Logs" Clicked="OnTabClicked" Style="{StaticResource TabBtn}" CommandParameter="Logs" />
            </HorizontalStackLayout>

            <Grid Grid.Row="1">
                <BlazorWebView x:Name="AiBlazorView" HostPage="wwwroot/index.html" IsVisible="True">
                    <BlazorWebView.RootComponents>
                        <RootComponent Selector="#app" ComponentType="{x:Type local:Components.Pages.HomePanels.WorkbenchPanel}" />
                    </BlazorWebView.RootComponents>
                </BlazorWebView>
                <WebView x:Name="AiStudioWebView" Source="https://aistudio.google.com/" IsVisible="False" />
            </Grid>
        </Grid>

    </Grid>
</ContentPage>